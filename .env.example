# OC Desktop Pet - API 配置
# 复制此文件为 .env 并填入你的 API 凭据
# 留空则回退到 Hanako 的 provider-catalog.json

# ── LLM（留空 = 用 Hanako 的默认配置）──
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# ── TTS API（tts.provider = api 时使用）──
TTS_BASE_URL=
TTS_API_KEY=
TTS_MODEL=tts-1
TTS_VOICE=alloy

# ── ASR API（asr.provider = api 时使用）──
ASR_BASE_URL=
ASR_API_KEY=
ASR_MODEL=whisper-1

# ── 手机活动感知 - MacroDroid 直连（可选）──
PHONE_RECEIVER_PORT=8077
PHONE_AUTH_TOKEN=

# ── 掌心窗 - linjian-peek 集成（可选）──
LINJIAN_URL=
LINJIAN_TOKEN=
