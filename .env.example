# ── Hanako 连接配置 ──
# 桌宠通过 Hanako WS 客户端与 Hanako 通信
# token 自动从 ~/.hanako/server-info.json 读取，通常无需手动配置
HANAKO_BASE_URL=http://127.0.0.1:14500
HANAKO_API_TOKEN=
# transport_mode: direct=直连LLM | prefer_hanako=优先Hanako(失败fallback) | hanako_only=仅Hanako
HANAKO_TRANSPORT_MODE=prefer_hanako
# 回复超时（秒），Hanako 模式下需要更长（搜索/生图等工具调用）
HANAKO_REPLY_TIMEOUT=180
# 是否同步显示外部（插件/Hanako主窗口）发起的对话
HANAKO_MIRROR_EXTERNAL_REPLIES=true

# ── LLM 配置（直连模式或 fallback 时使用）──
# 优先读取此配置，为空时回退到 Hanako provider-catalog.json
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# ── TTS 配置 ──
# CosyVoice 本地 / API / 浏览器自动降级
TTS_ENABLED=true
TTS_PROVIDER=auto
